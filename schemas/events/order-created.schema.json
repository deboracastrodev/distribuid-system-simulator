{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "order-created.schema.json",
  "title": "OrderCreated Event",
  "description": "Schema do campo data para o evento OrderCreated (seq_id: 1)",
  "type": "object",
  "properties": {
    "user_id": {
      "type": "string",
      "description": "ID do usuario que criou o pedido"
    },
    "items": {
      "type": "array",
      "minItems": 1,
      "description": "Lista de itens do pedido",
      "items": {
        "type": "object",
        "properties": {
          "product_id": {
            "type": "string",
            "description": "ID do produto"
          },
          "quantity": {
            "type": "integer",
            "minimum": 1,
            "description": "Quantidade solicitada"
          },
          "unit_price": {
            "type": "number",
            "minimum": 0,
            "description": "Preco unitario do produto"
          }
        },
        "required": ["product_id", "quantity", "unit_price"],
        "additionalProperties": false
      }
    },
    "total_amount": {
      "type": "number",
      "minimum": 0,
      "description": "Valor total do pedido"
    },
    "currency": {
      "type": "string",
      "default": "BRL",
      "description": "Moeda do pedido (default: BRL)"
    }
  },
  "required": ["user_id", "items", "total_amount", "currency"],
  "additionalProperties": false
}
